PORT=3000

# Banco: se definido usa PostgreSQL (produção). Vazio = SQLite local.
DATABASE_URL=

# CORS: URL do frontend em produção. Vazio em dev = permite qualquer origem.
FRONTEND_URL=

# JWT: use uma string longa e aleatória em produção.
JWT_SECRET=troque-este-segredo-em-producao

# pagar.me — obtenha em dashboard.pagar.me → Configurações → Chaves de API
PAGARME_API_KEY=
PAGARME_WEBHOOK_SECRET=
PAGARME_API_URL=https://api.pagar.me/core/v5

# Asaas — obtenha em app.asaas.com → Configurações → Integrações → Chave de API
# Sandbox: https://sandbox.asaas.com/api/v3 | Produção: https://api.asaas.com/v3
ASAAS_API_KEY=
ASAAS_API_URL=https://sandbox.asaas.com/api/v3
# Token aleatório para autenticar o webhook: /billing/webhook/asaas?token=SEU_TOKEN
ASAAS_WEBHOOK_TOKEN=
